leading-relaxed mb-3 last:mb-0" node=3D"[object Object]">Here=E2=80=99s a c=
omplete single-file <span class=3D"font-semibold" data-streamdown=3D"strong=
">HTML app</span> for a simple 8-bit-style 2D platformer with:</p>
<ul class=3D"list-disc list-inside space-y-1 mb-3 ml-1" node=3D"[object Obj=
ect]">
<li class=3D"leading-relaxed" node=3D"[object Object]">a <span class=3D"fon=
t-semibold" data-streamdown=3D"strong">lime green bipedal lizard</span></li=
>
<li class=3D"leading-relaxed" node=3D"[object Object]"><span class=3D"font-=
semibold" data-streamdown=3D"strong">platform jumping</span></li>
<li class=3D"leading-relaxed" node=3D"[object Object]">a <span class=3D"fon=
t-semibold" data-streamdown=3D"strong">flag</span> to finish each level</li=
>
<li class=3D"leading-relaxed" node=3D"[object Object]"><span class=3D"font-=
semibold" data-streamdown=3D"strong">bug enemies</span></li>
<li class=3D"leading-relaxed" node=3D"[object Object]">touching a bug <span=
 class=3D"font-semibold" data-streamdown=3D"strong">restarts the level</spa=
n></li>
<li class=3D"leading-relaxed" node=3D"[object Object]">jumping on a bug=E2=
=80=99s <span class=3D"font-semibold" data-streamdown=3D"strong">head defea=
ts it</span></li>
</ul>
<p class=3D"leading-relaxed mb-3 last:mb-0" node=3D"[object Object]">Save t=
his as <code class=3D"px-1.5 py-0.5 rounded bg-muted text-sm font-mono" nod=
e=3D"[object Object]">index.html</code> and open it in a browser.</p>
<pre class=3D"my-3 rounded-lg border border-border overflow-x-auto bg-[oklc=
h(0.15_0_0)] p-3 text-sm leading-relaxed" node=3D"[object Object]"><code cl=
ass=3D"language-html" node=3D"[object Object]">&lt;!DOCTYPE html&gt;
&lt;html lang=3D"en"&gt;
&lt;head&gt;
  &lt;meta charset=3D"UTF-8" /&gt;
  &lt;meta name=3D"viewport" content=3D"width=3Ddevice-width, initial-scale=
=3D1.0" /&gt;
  &lt;title&gt;Lizard Leap&lt;/title&gt;
  &lt;style&gt;
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: #1d1d2a;
      color: white;
      font-family: monospace;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }
    h1 {
      margin: 12px 0 4px;
      font-size: 20px;
      letter-spacing: 2px;
    }
    p {
      margin: 0 0 10px;
      font-size: 12px;
      color: #cfd3ff;
    }
    canvas {
      border: 4px solid #ffffff;
      image-rendering: pixelated;
      image-rendering: crisp-edges;
      background: #7ec8ff;
      max-width: 100vw;
      max-height: 85vh;
    }
  &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
  &lt;h1&gt;LIZARD LEAP&lt;/h1&gt;
  &lt;p&gt;Move: Arrow Keys / A D &amp;nbsp; Jump: Space / W / Up &amp;nbsp=
; R: Restart&lt;/p&gt;
  &lt;canvas id=3D"game" width=3D"960" height=3D"540"&gt;&lt;/canvas&gt;

  &lt;script&gt;
    const canvas =3D document.getElementById("game");
    const ctx =3D canvas.getContext("2d");

    const GRAVITY =3D 0.6;
    const MOVE_SPEED =3D 3.2;
    const JUMP_POWER =3D -11;
    const FRICTION =3D 0.85;

    const keys =3D {};
    addEventListener("keydown", e =3D&gt; {
      keys[e.key.toLowerCase()] =3D true;
      if (["arrowup","arrowdown","arrowleft","arrowright"," "].includes(e.k=
ey.toLowerCase())) {
        e.preventDefault();
      }
    });
    addEventListener("keyup", e =3D&gt; {
      keys[e.key.toLowerCase()] =3D false;
    });

    const levels =3D [
      {
        playerStart: { x: 60, y: 420 },
        flag: { x: 875, y: 180, w: 20, h: 60 },
        platforms: [
          { x: 0, y: 500, w: 960, h: 40 },
          { x: 120, y: 430, w: 120, h: 20 },
          { x: 300, y: 380, w: 120, h: 20 },
          { x: 470, y: 320, w: 120, h: 20 },
          { x: 650, y: 260, w: 120, h: 20 },
          { x: 820, y: 240, w: 100, h: 20 }
        ],
        bugs: [
          { x: 340, y: 356, w: 28, h: 24, left: 310, right: 390, dir: 1, sp=
eed: 1.1 },
          { x: 690, y: 236, w: 28, h: 24, left: 660, right: 740, dir: -1, s=
peed: 1.4 }
        ]
      },
      {
        playerStart: { x: 40, y: 420 },
        flag: { x: 885, y: 110, w: 20, h: 60 },
        platforms: [
          { x: 0, y: 500, w: 960, h: 40 },
          { x: 90, y: 440, w: 100, h: 20 },
          { x: 230, y: 390, w: 90, h: 20 },
          { x: 360, y: 340, w: 90, h: 20 },
          { x: 500, y: 290, w: 90, h: 20 },
          { x: 640, y: 240, w: 90, h: 20 },
          { x: 760, y: 180, w: 90, h: 20 },
          { x: 850, y: 130, w: 70, h: 20 }
        ],
        bugs: [
          { x: 248, y: 366, w: 28, h: 24, left: 235, right: 290, dir: 1, sp=
eed: 1.3 },
          { x: 528, y: 266, w: 28, h: 24, left: 505, right: 565, dir: -1, s=
peed: 1.6 },
          { x: 778, y: 156, w: 28, h: 24, left: 765, right: 820, dir: 1, sp=
eed: 1.2 }
        ]
      }
    ];

    let currentLevel =3D 0;
    let levelData;
    let player;
    let bugs;
    let wonGame =3D false;
    let levelMessageTimer =3D 0;

    function rectsOverlap(a, b) {
      return (
        a.x &lt; b.x + b.w &amp;&amp;
        a.x + a.w &gt; b.x &amp;&amp;
        a.y &lt; b.y + b.h &amp;&amp;
        a.y + a.h &gt; b.y
      );
    }

    function resetLevel() {
      levelData =3D JSON.parse(JSON.stringify(levels[currentLevel]));
      player =3D {
        x: levelData.playerStart.x,
        y: levelData.playerStart.y,
        w: 28,
        h: 36,
        vx: 0,
        vy: 0,
        onGround: false,
        facing: 1
      };
      bugs =3D levelData.bugs.map(b =3D&gt; ({ ...b, alive: true }));
    }

    function nextLevel() {
      currentLevel++;
      if (currentLevel &gt;=3D levels.length) {
        wonGame =3D true;
      } else {
        levelMessageTimer =3D 90;
        resetLevel();
      }
    }

    function stompBug(bug) {
      bug.alive =3D false;
      player.vy =3D -7;
    }

    function restartLevel() {
      resetLevel();
    }

    function updatePlayer() {
      const left =3D keys["arrowleft"] || keys["a"];
      const right =3D keys["arrowright"] || keys["d"];
      const jump =3D keys["arrowup"] || keys["w"] || keys[" "];

      if (left) {
        player.vx -=3D 0.5;
        player.facing =3D -1;
      }
      if (right) {
        player.vx +=3D 0.5;
        player.facing =3D 1;
      }

      if (!left &amp;&amp; !right) {
        player.vx *=3D FRICTION;
      }

      player.vx =3D Math.max(-MOVE_SPEED, Math.min(MOVE_SPEED, player.vx));

      if (jump &amp;&amp; player.onGround) {
        player.vy =3D JUMP_POWER;
        player.onGround =3D false;
      }

      player.vy +=3D GRAVITY;

      // Horizontal move
      player.x +=3D player.vx;
      for (const p of levelData.platforms) {
        if (rectsOverlap(player, p)) {
          if (player.vx &gt; 0) player.x =3D p.x - player.w;
          if (player.vx &lt; 0) player.x =3D p.x + p.w;
          player.vx =3D 0;
        }
      }

      // Vertical move
      player.y +=3D player.vy;
      player.onGround =3D false;
      for (const p of levelData.platforms) {
        if (rectsOverlap(player, p)) {
          if (player.vy &gt; 0) {
            player.y =3D p.y - player.h;
            player.vy =3D 0;
            player.onGround =3D true;
          } else if (player.vy &lt; 0) {
            player.y =3D p.y + p.h;
            player.vy =3D 0;
          }
        }
      }

      if (player.y &gt; canvas.height + 100) {
        restartLevel();
      }

      if (player.x &lt; 0) player.x =3D 0;
      if (player.x + player.w &gt; canvas.width) player.x =3D canvas.width =
- player.w;

      if (keys["r"]) restartLevel();
    }

    function updateBugs() {
      for (const bug of bugs) {
        if (!bug.alive) continue;
        bug.x +=3D bug.speed * bug.dir;
        if (bug.x &lt;=3D bug.left) {
          bug.x =3D bug.left;
          bug.dir =3D 1;
        }
        if (bug.x + bug.w &gt;=3D bug.right) {
          bug.x =3D bug.right - bug.w;
          bug.dir =3D -1;
        }

        if (rectsOverlap(player, bug)) {
          const playerBottom =3D player.y + player.h;
          const bugTop =3D bug.y;
          const falling =3D player.vy &gt; 0;

          if (falling &amp;&amp; playerBottom - player.vy &lt;=3D bugTop + =
8) {
            stompBug(bug);
          } else {
            restartLevel();
            return;
          }
        }
      }
    }

    function checkFlag() {
      if (rectsOverlap(player, levelData.flag)) {
        nextLevel();
      }
    }

    function drawBackground() {
      ctx.fillStyle =3D "#7ec8ff";
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      // Hills
      ctx.fillStyle =3D "#6cc46c";
      ctx.fillRect(0, 440, canvas.width, 100);

      ctx.fillStyle =3D "#5ab45a";
      for (let i =3D 0; i &lt; 6; i++) {
        const x =3D i * 180 - 20;
        ctx.beginPath();
        ctx.arc(x + 90, 460, 80, Math.PI, 2 * Math.PI);
        ctx.fill();
      }

      // Clouds
      ctx.fillStyle =3D "white";
      drawCloud(120, 70);
      drawCloud(340, 120);
      drawCloud(700, 80);
    }

    function drawCloud(x, y) {
      ctx.fillRect(x, y, 60, 20);
      ctx.fillRect(x + 10, y - 10, 20, 10);
      ctx.fillRect(x + 30, y - 20, 20, 20);
      ctx.fillRect(x + 50, y - 10, 20, 10);
    }

    function drawPlatforms() {
      for (const p of levelData.platforms) {
        ctx.fillStyle =3D "#7a4f2a";
        ctx.fillRect(p.x, p.y, p.w, p.h);
        ctx.fillStyle =3D "#a06a3a";
        ctx.fillRect(p.x, p.y, p.w, 6);

        ctx.fillStyle =3D "#2f9e44";
        for (let gx =3D p.x; gx &lt; p.x + p.w; gx +=3D 12) {
          ctx.fillRect(gx, p.y - 6, 8, 6);
        }
      }
    }

    function drawFlag(flag) {
      ctx.fillStyle =3D "#ddd";
      ctx.fillRect(flag.x, flag.y, 4, flag.h);
      ctx.fillStyle =3D "#ff2d55";
      ctx.fillRect(flag.x + 4, flag.y, 24, 16);
      ctx.fillStyle =3D "#ffffff";
      ctx.fillRect(flag.x + 10, flag.y + 4, 6, 4);
    }

    function drawBug(b) {
      if (!b.alive) return;
      ctx.fillStyle =3D "#5b3a29";
      ctx.fillRect(b.x, b.y + 8, b.w, b.h - 8);

      ctx.fillStyle =3D "#2b1b12";
      ctx.fillRect(b.x + 4, b.y + 2, b.w - 8, 10);

      ctx.fillStyle =3D "#ffef66";
      ctx.fillRect(b.x + 6, b.y + 6, 4, 4);
      ctx.fillRect(b.x + b.w - 10, b.y + 6, 4, 4);

      ctx.fillStyle =3D "#2b1b12";
      for (let i =3D 0; i &lt; 3; i++) {
        ctx.fillRect(b.x - 4, b.y + 8 + i * 5, 4, 2);
        ctx.fillRect(b.x + b.w, b.y + 8 + i * 5, 4, 2);
      }
    }

    function drawPlayer() {
      const x =3D Math.round(player.x);
      const y =3D Math.round(player.y);

      // Tail
      ctx.fillStyle =3D "#54d437";
      if (player.facing =3D=3D=3D 1) {
        ctx.fillRect(x - 6, y + 18, 8, 4);
      } else {
        ctx.fillRect(x + player.w - 2, y + 18, 8, 4);
      }

      // Body
      ctx.fillStyle =3D "#7CFC00";
      ctx.fillRect(x + 6, y + 8, 16, 20);

      // Head
      ctx.fillRect(x + 4, y, 20, 14);

      // Legs
      ctx.fillStyle =3D "#62d62f";
      ctx.fillRect(x + 7, y + 28, 5, 8);
      ctx.fillRect(x + 16, y + 28, 5, 8);

      // Arms
      ctx.fillRect(x + 2, y + 12, 4, 8);
      ctx.fillRect(x + 22, y + 12, 4, 8);

      // Eye
      ctx.fillStyle =3D "#000";
      if (player.facing =3D=3D=3D 1) {
        ctx.fillRect(x + 17, y + 4, 3, 3);
      } else {
        ctx.fillRect(x + 8, y + 4, 3, 3);
      }

      // Belly
      ctx.fillStyle =3D "#b6ff7a";
      ctx.fillRect(x + 10, y + 12, 8, 10);
    }

    function drawUI() {
      ctx.fillStyle =3D "#00000088";
      ctx.fillRect(10, 10, 180, 52);
      ctx.fillStyle =3D "#fff";
      ctx.font =3D "16px monospace";
      ctx.fillText(`Level: ${currentLevel + 1}/${levels.length}`, 20, 32);
      ctx.fillText("Reach the flag!", 20, 52);

      if (levelMessageTimer &gt; 0) {
        ctx.fillStyle =3D "#00000099";
        ctx.fillRect(canvas.width / 2 - 90, 30, 180, 40);
        ctx.fillStyle =3D "#fff";
        ctx.fillText("LEVEL COMPLETE!", canvas.width / 2 - 72, 55);
      }
    }

    function drawWinScreen() {
      ctx.fillStyle =3D "#1d1d2a";
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle =3D "#7CFC00";
      ctx.font =3D "32px monospace";
      ctx.fillText("YOU WIN!", canvas.width / 2 - 90, 220);
      ctx.fillStyle =3D "#fff";
      ctx.font =3D "18px monospace";
      ctx.fillText("The lizard reached every flag.", canvas.width / 2 - 160=
, 270);
      ctx.fillText("Press R to play again.", canvas.width / 2 - 120, 310);

      if (keys["r"]) {
        currentLevel =3D 0;
        wonGame =3D false;
        resetLevel();
      }
    }

    function update() {
      if (wonGame) return;

      updatePlayer();
      updateBugs();
      checkFlag();

      if (levelMessageTimer &gt; 0) levelMessageTimer--;
    }

    function draw() {
      if (wonGame) {
        drawWinScreen();
        return;
      }

      drawBackground();
      drawPlatforms();
      drawFlag(levelData.flag);
      for (const bug of bugs) drawBug(bug);
      drawPlayer();
      drawUI();
    }

    function loop() {
      update();
      draw();
      requestAnimationFrame(loop);
    }

    resetLevel();
    loop();
  &lt;/script&gt;
